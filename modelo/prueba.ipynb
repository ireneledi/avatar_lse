     "text": [
      "Enviar a Unity en 127.0.0.1:9\n",
      "Frase LSE: video a video video a a a a a video a\n",
      "Enviado: video_anim,a_anim,video_anim,video_anim,a_anim,a_anim,a_anim,a_anim,a_anim,video_anim,a_anim\n"
     ]
    }
   ],
   "source": [
    "import socket\n",
    "\n",
    "UDP_IP = \"127.0.0.1\"\n",
    "UDP_PORT = 9 \n",
    "\n",
    "print(f\"Enviar a Unity en {UDP_IP}:{UDP_PORT}\")\n",
    "\n",
    "sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM) # UDP\n",
    "\n",
    "mensaje_final_lse = procesar_frase(\"video a video video a a a a a video a\")\n",
    "\n",
    "def enviar_a_unity(secuencia):\n",
    "    # convertimos el texto a bytes (utf-8)\n",
    "    mensaje_bytes = secuencia.encode('utf-8')\n",
    "    \n",
    "    sock.sendto(mensaje_bytes, (UDP_IP, UDP_PORT))\n",
    "    print(f\"Enviado: {secuencia}\")\n",
    "\n",
    "enviar_a_unity(mensaje_final_lse)"
   ]
  },
